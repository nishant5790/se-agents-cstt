# Copy to .env. All optional — without these the team runs fully offline
# (keyword-based understanding + deterministic deck planning).

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# Path to a Vosk model for video/audio transcription (offline).
# Defaults to ../tetris_mvp/models/vosk-model-small-en-us-0.15
VOSK_MODEL_PATH=

# Max video frames sampled per media file (evenly spaced) for slide visuals.
MEDIA_MAX_FRAMES=60
